<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.17.xsd">

    <changeSet id="3.11.0:LARGE_FILE_UPLOAD_INFO" author="EZL">
        <createTable tableName="large_file_upload_info">
            <column name="tus_id" type="text">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pk_large_file_upload_info"></constraints>
            </column>
            <column name="asset_guid" type="text">
                <constraints nullable="false"/>
            </column>
            <column name="size_bytes" type="bigint">
                <constraints nullable="false"/>
            </column>
            <column name="path" type="text">
                <constraints nullable="false"/>
            </column>
            <column name="created_data" type="timestamp" defaultValue="now()">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="VERSION-3.11.0" author="EZL" context="default">
        <tagDatabase tag="VERSION-3.11.0"/>
    </changeSet>

</databaseChangeLog>