        <mxCell id="e-8" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#666666;strokeWidth=2;startArrow=none;endArrow=block;fontSize=12;labelBackgroundColor=#ffffff;fontFamily=Helvetica;" parent="1" edge="1" source="c-6" target="c-7">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="c-9" value="POST file-proxy /asset-bundles/jobs&lt;br/&gt;Internal request includes bearer token." style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;strokeWidth=1.5;fontSize=15;align=left;verticalAlign=top;spacing=14;spacingLeft=16;spacingRight=16;spacingTop=12;spacingBottom=12;fontFamily=Helvetica;" parent="1" vertex="1">
          <mxGeometry x="130" y="526" width="900" height="105" as="geometry" />
        </mxCell>
        <mxCell id="e-10" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#666666;strokeWidth=2;startArrow=none;endArrow=block;fontSize=12;labelBackgroundColor=#ffffff;fontFamily=Helvetica;" parent="1" edge="1" source="c-7" target="c-9">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="c-11" value="File-proxy asks ARS to validate read access&lt;br/&gt;POST /v1/assets/readaccessforzip." style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;strokeWidth=1.5;fontSize=15;align=left;verticalAlign=top;spacing=14;spacingLeft=16;spacingRight=16;spacingTop=12;spacingBottom=12;fontFamily=Helvetica;" parent="1" vertex="1">
