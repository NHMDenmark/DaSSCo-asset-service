        </mxCell>
        <mxCell id="c-37" value="Grant failure special case&lt;br/&gt;If WRITE is missing for some assets, the error body can contain those asset GUIDs.&lt;br/&gt;The UI opens IllegalAssetGroupDialog with removable=true." style="shape=note;whiteSpace=wrap;html=1;boundedLbl=1;fillColor=#f8cecc;strokeColor=#b85450;strokeWidth=1.5;fontSize=15;align=left;verticalAlign=top;spacing=14;spacingLeft=16;spacingRight=16;spacingTop=12;spacingBottom=12;fontFamily=Helvetica;" parent="1" vertex="1">
          <mxGeometry x="410" y="1490" width="1580" height="150" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
