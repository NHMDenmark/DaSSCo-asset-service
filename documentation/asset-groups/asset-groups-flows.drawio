        <mxCell id="e-20" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#666666;strokeWidth=2;startArrow=none;endArrow=block;fontSize=12;labelBackgroundColor=#ffffff;fontFamily=Helvetica;" parent="1" edge="1" source="c-17" target="c-19">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="c-21" value="CSV metadata download" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;strokeWidth=1.5;fontSize=17;fontStyle=1;align=center;verticalAlign=middle;spacing=14;spacingLeft=16;spacingRight=16;spacingTop=12;spacingBottom=12;fontFamily=Helvetica;" parent="1" vertex="1">
          <mxGeometry x="1260" y="150" width="1000" height="44" as="geometry" />
        </mxCell>
        <mxCell id="c-22" value="User chooses Download CSV&lt;br/&gt;for selected group assets." style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;strokeWidth=1.5;fontSize=15;align=left;verticalAlign=top;spacing=14;spacingLeft=16;spacingRight=16;spacingTop=12;spacingBottom=12;fontFamily=Helvetica;" parent="1" vertex="1">
          <mxGeometry x="1300" y="240" width="900" height="105" as="geometry" />
        </mxCell>
        <mxCell id="c-23" value="DetailedViewService.postCsv(assetGuids)&lt;br/&gt;POST file-proxy /createCsvFile." style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;strokeWidth=1.5;fontSize=15;align=left;verticalAlign=top;spacing=14;spacingLeft=16;spacingRight=16;spacingTop=12;spacingBottom=12;fontFamily=Helvetica;" parent="1" vertex="1">
          <mxGeometry x="1300" y="383" width="900" height="105" as="geometry" />
        </mxCell>
        <mxCell id="e-24" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#666666;strokeWidth=2;startArrow=none;endArrow=block;fontSize=12;labelBackgroundColor=#ffffff;fontFamily=Helvetica;" parent="1" edge="1" source="c-22" target="c-23">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="c-25" value="File-proxy asks ARS for CSV&lt;br/&gt;POST /v1/assets/readaccessforcsv." style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;strokeWidth=1.5;fontSize=15;align=left;verticalAlign=top;spacing=14;spacingLeft=16;spacingRight=16;spacingTop=12;spacingBottom=12;fontFamily=Helvetica;" parent="1" vertex="1">
          <mxGeometry x="1300" y="526" width="900" height="105" as="geometry" />
        </mxCell>
        <mxCell id="e-26" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#666666;strokeWidth=2;startArrow=none;endArrow=block;fontSize=12;labelBackgroundColor=#ffffff;fontFamily=Helvetica;" parent="1" edge="1" source="c-23" target="c-25">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="c-27" value="ARS checks read access for every asset.&lt;br/&gt;BulkUpdateService creates CSV string." style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;strokeWidth=1.5;fontSize=15;align=left;verticalAlign=top;spacing=14;spacingLeft=16;spacingRight=16;spacingTop=12;spacingBottom=12;fontFamily=Helvetica;" parent="1" vertex="1">
          <mxGeometry x="1300" y="669" width="900" height="105" as="geometry" />
        </mxCell>
        <mxCell id="e-28" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#666666;strokeWidth=2;startArrow=none;endArrow=block;fontSize=12;labelBackgroundColor=#ffffff;fontFamily=Helvetica;" parent="1" edge="1" source="c-25" target="c-27">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="c-29" value="File-proxy writes temp file&lt;br/&gt;{guid}/assets.csv." style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;strokeWidth=1.5;fontSize=15;align=left;verticalAlign=top;spacing=14;spacingLeft=16;spacingRight=16;spacingTop=12;spacingBottom=12;fontFamily=Helvetica;" parent="1" vertex="1">
          <mxGeometry x="1300" y="812" width="900" height="105" as="geometry" />
        </mxCell>
        <mxCell id="e-30" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#666666;strokeWidth=2;startArrow=none;endArrow=block;fontSize=12;labelBackgroundColor=#ffffff;fontFamily=Helvetica;" parent="1" edge="1" source="c-27" target="c-29">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="c-31" value="Angular GETs temp file as blob&lt;br/&gt;and triggers browser download." style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;strokeWidth=1.5;fontSize=15;align=left;verticalAlign=top;spacing=14;spacingLeft=16;spacingRight=16;spacingTop=12;spacingBottom=12;fontFamily=Helvetica;" parent="1" vertex="1">
          <mxGeometry x="1300" y="955" width="900" height="105" as="geometry" />
        </mxCell>
        <mxCell id="e-32" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#666666;strokeWidth=2;startArrow=none;endArrow=block;fontSize=12;labelBackgroundColor=#ffffff;fontFamily=Helvetica;" parent="1" edge="1" source="c-29" target="c-31">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="c-33" value="Angular DELETEs temp folder." style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;strokeWidth=1.5;fontSize=15;align=left;verticalAlign=top;spacing=14;spacingLeft=16;spacingRight=16;spacingTop=12;spacingBottom=12;fontFamily=Helvetica;" parent="1" vertex="1">
          <mxGeometry x="1300" y="1098" width="900" height="105" as="geometry" />
        </mxCell>
        <mxCell id="e-34" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#666666;strokeWidth=2;startArrow=none;endArrow=block;fontSize=12;labelBackgroundColor=#ffffff;fontFamily=Helvetica;" parent="1" edge="1" source="c-31" target="c-33">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="c-35" value="UI shows snackbar on create/get/delete error." style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;strokeWidth=1.5;fontSize=15;align=left;verticalAlign=top;spacing=14;spacingLeft=16;spacingRight=16;spacingTop=12;spacingBottom=12;fontFamily=Helvetica;" parent="1" vertex="1">
          <mxGeometry x="1300" y="1241" width="900" height="105" as="geometry" />
        </mxCell>
        <mxCell id="e-36" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#666666;strokeWidth=2;startArrow=none;endArrow=block;fontSize=12;labelBackgroundColor=#ffffff;fontFamily=Helvetica;" parent="1" edge="1" source="c-33" target="c-35">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="c-37" value="ZIP failure states&lt;br/&gt;Start, poll, or download errors mark the download as FAILED.&lt;br/&gt;Cancel removes pending work or DELETEs the file-proxy job.&lt;br/&gt;File-proxy can also reject a bundle that is too large." style="shape=note;whiteSpace=wrap;html=1;boundedLbl=1;fillColor=#f8cecc;strokeColor=#b85450;strokeWidth=1.5;fontSize=15;align=left;verticalAlign=top;spacing=14;spacingLeft=16;spacingRight=16;spacingTop=12;spacingBottom=12;fontFamily=Helvetica;" parent="1" vertex="1">
          <mxGeometry x="350" y="1540" width="1600" height="160" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram name="7. Role and access checks" id="page-2">
    <mxGraphModel dx="2400" dy="1700" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2400" pageHeight="1700" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="c-3" value="7. Role and access checks" style="text;html=1;strokeColor=none;fillColor=none;whiteSpace=wrap;overflow=hidden;fontSize=28;fontStyle=1;fontColor=#000000;align=left;verticalAlign=middle;spacing=0;fontFamily=Helvetica;" parent="1" vertex="1">
          <mxGeometry x="40" y="26" width="2320" height="40" as="geometry" />
        </mxCell>
        <mxCell id="c-4" value="The feature uses three layers of checks. Each operation chooses the layer it needs." style="text;html=1;strokeColor=none;fillColor=none;whiteSpace=wrap;overflow=hidden;fontSize=15;fontColor=#555555;align=left;verticalAlign=middle;spacing=0;fontFamily=Helvetica;" parent="1" vertex="1">
          <mxGeometry x="40" y="72" width="2320" height="36" as="geometry" />
        </mxCell>
        <mxCell id="c-5" value="1. Endpoint role gate&lt;br/&gt;@RolesAllowed allows ADMIN, DEVELOPER, SERVICE, or USER on asset-group endpoints.&lt;br/&gt;Requests without these roles are rejected before service logic." style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;strokeWidth=1.5;fontSize=15;align=left;verticalAlign=top;spacing=14;spacingLeft=16;spacingRight=16;spacingTop=12;spacingBottom=12;fontFamily=Helvetica;" parent="1" vertex="1">
          <mxGeometry x="120" y="190" width="620" height="190" as="geometry" />
        </mxCell>
        <mxCell id="c-6" value="2a. Group read access&lt;br/&gt;Allowed if admin/developer/service OR username is in asset_group_access.&lt;br/&gt;Used when reading group assets." style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;strokeWidth=1.5;fontSize=15;align=left;verticalAlign=top;spacing=14;spacingLeft=16;spacingRight=16;spacingTop=12;spacingBottom=12;fontFamily=Helvetica;" parent="1" vertex="1">
          <mxGeometry x="910" y="190" width="620" height="170" as="geometry" />
        </mxCell>
        <mxCell id="c-7" value="2b. Group management access&lt;br/&gt;Allowed if admin/developer/service OR user is the creator/owner.&lt;br/&gt;Used for edit, grant, revoke, and delete." style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;strokeWidth=1.5;fontSize=15;align=left;verticalAlign=top;spacing=14;spacingLeft=16;spacingRight=16;spacingTop=12;spacingBottom=12;fontFamily=Helvetica;" parent="1" vertex="1">
          <mxGeometry x="1660" y="190" width="620" height="170" as="geometry" />
        </mxCell>
        <mxCell id="e-8" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#666666;strokeWidth=2;startArrow=none;endArrow=block;fontSize=12;labelBackgroundColor=#ffffff;fontFamily=Helvetica;" parent="1" edge="1" source="c-5" target="c-6">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e-9" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#666666;strokeWidth=2;startArrow=none;endArrow=block;fontSize=12;labelBackgroundColor=#ffffff;fontFamily=Helvetica;" parent="1" edge="1" source="c-5" target="c-7">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="c-10" value="3. Per-asset role checks&lt;br/&gt;checkRightsAsset(user, asset, read/write) checks:&lt;br/&gt;asset role restrictions, specimen role restrictions, collection restrictions, and institution restrictions.&lt;br/&gt;WRITE roles also imply READ." style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;strokeWidth=1.5;fontSize=15;align=left;verticalAlign=top;spacing=14;spacingLeft=16;spacingRight=16;spacingTop=12;spacingBottom=12;fontFamily=Helvetica;" parent="1" vertex="1">
          <mxGeometry x="620" y="520" width="1150" height="220" as="geometry" />
        </mxCell>
        <mxCell id="e-11" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#666666;strokeWidth=2;startArrow=none;endArrow=block;fontSize=12;labelBackgroundColor=#ffffff;fontFamily=Helvetica;" parent="1" edge="1" source="c-6" target="c-10">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e-12" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#666666;strokeWidth=2;startArrow=none;endArrow=block;fontSize=12;labelBackgroundColor=#ffffff;fontFamily=Helvetica;" parent="1" edge="1" source="c-7" target="c-10">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="c-13" value="Operation matrix&lt;br/&gt;List groups: SQL filters by asset_group_access.&lt;br/&gt;Read group assets: group read + READ on every asset.&lt;br/&gt;Create without users: READ on every requested asset.&lt;br/&gt;Create with users: WRITE on every requested asset.&lt;br/&gt;Add assets: owner/admin + READ or WRITE depending on whether group is shared.&lt;br/&gt;Grant access: owner/admin + WRITE on every asset already in the group.&lt;br/&gt;Remove assets, revoke users, delete group: owner/admin.&lt;br/&gt;ZIP/CSV download: READ on every selected asset.&lt;br/&gt;Bulk audit: endpoint gate plus audit rules in AssetService." style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;strokeWidth=1.5;fontSize=15;align=left;verticalAlign=top;spacing=14;spacingLeft=16;spacingRight=16;spacingTop=12;spacingBottom=12;fontFamily=Helvetica;" parent="1" vertex="1">
          <mxGeometry x="220" y="890" width="1960" height="360" as="geometry" />
        </mxCell>
        <mxCell id="c-14" value="Denied checks&lt;br/&gt;Service throws DasscoIllegalActionException or IllegalArgumentException.&lt;br/&gt;Exception mappers return DaSSCoError.&lt;br/&gt;Angular shows snackbar or an error dialog." style="shape=note;whiteSpace=wrap;html=1;boundedLbl=1;fillColor=#f8cecc;strokeColor=#b85450;strokeWidth=1.5;fontSize=15;align=left;verticalAlign=top;spacing=14;spacingLeft=16;spacingRight=16;spacingTop=12;spacingBottom=12;fontFamily=Helvetica;" parent="1" vertex="1">
          <mxGeometry x="580" y="1360" width="1240" height="150" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram name="8. Delete groups and audit assets" id="page-2">
    <mxGraphModel dx="2400" dy="1700" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2400" pageHeight="1700" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="c-3" value="8. Delete groups and audit assets" style="text;html=1;strokeColor=none;fillColor=none;whiteSpace=wrap;overflow=hidden;fontSize=28;fontStyle=1;fontColor=#000000;align=left;verticalAlign=middle;spacing=0;fontFamily=Helvetica;" parent="1" vertex="1">
