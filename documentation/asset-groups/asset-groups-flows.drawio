        <mxCell id="e-12" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#666666;strokeWidth=2;startArrow=none;endArrow=block;fontSize=12;labelBackgroundColor=#ffffff;fontFamily=Helvetica;" parent="1" edge="1" source="c-9" target="c-11">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="c-13" value="ARS checks every asset with checkRightsAsset(read)." style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;strokeWidth=1.5;fontSize=15;align=left;verticalAlign=top;spacing=14;spacingLeft=16;spacingRight=16;spacingTop=12;spacingBottom=12;fontFamily=Helvetica;" parent="1" vertex="1">
          <mxGeometry x="130" y="812" width="900" height="105" as="geometry" />
        </mxCell>
        <mxCell id="e-14" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#666666;strokeWidth=2;startArrow=none;endArrow=block;fontSize=12;labelBackgroundColor=#ffffff;fontFamily=Helvetica;" parent="1" edge="1" source="c-11" target="c-13">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="c-15" value="File-proxy gathers files and builds bundle job." style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;strokeWidth=1.5;fontSize=15;align=left;verticalAlign=top;spacing=14;spacingLeft=16;spacingRight=16;spacingTop=12;spacingBottom=12;fontFamily=Helvetica;" parent="1" vertex="1">
          <mxGeometry x="130" y="955" width="900" height="105" as="geometry" />
        </mxCell>
        <mxCell id="e-16" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#666666;strokeWidth=2;startArrow=none;endArrow=block;fontSize=12;labelBackgroundColor=#ffffff;fontFamily=Helvetica;" parent="1" edge="1" source="c-13" target="c-15">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="c-17" value="Angular polls jobs/{jobId} every 3 seconds.&lt;br/&gt;READY downloads jobs/{jobId}/download." style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;strokeWidth=1.5;fontSize=15;align=left;verticalAlign=top;spacing=14;spacingLeft=16;spacingRight=16;spacingTop=12;spacingBottom=12;fontFamily=Helvetica;" parent="1" vertex="1">
          <mxGeometry x="130" y="1098" width="900" height="105" as="geometry" />
