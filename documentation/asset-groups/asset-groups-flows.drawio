          <mxGeometry x="130" y="240" width="900" height="105" as="geometry" />
        </mxCell>
        <mxCell id="c-7" value="AssetBundleDownloadService&lt;br/&gt;De-dupes GUIDs and creates PREPARING item." style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;strokeWidth=1.5;fontSize=15;align=left;verticalAlign=top;spacing=14;spacingLeft=16;spacingRight=16;spacingTop=12;spacingBottom=12;fontFamily=Helvetica;" parent="1" vertex="1">
