        <mxCell id="c-19" value="Browser downloads blob.&lt;br/&gt;Status item is removed." style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;strokeWidth=1.5;fontSize=15;align=left;verticalAlign=top;spacing=14;spacingLeft=16;spacingRight=16;spacingTop=12;spacingBottom=12;fontFamily=Helvetica;" parent="1" vertex="1">
          <mxGeometry x="130" y="1241" width="900" height="105" as="geometry" />
