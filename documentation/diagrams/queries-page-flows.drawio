        <mxCell id="p2_06" value="UserService.from() builds User from JWT" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=14;align=center;verticalAlign=middle;fillColor=#ffffff;strokeColor=#6c8ebf;spacing=10;arcSize=8;" parent="1" vertex="1">
