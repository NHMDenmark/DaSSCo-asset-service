        </mxCell>
        <mxCell id="p2_n01" value="The result call and count call are independent frontend subscriptions started by save()." style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=14;align=left;verticalAlign=top;fillColor=#f5f5f5;strokeColor=#666666;spacing=12;arcSize=8;" parent="1" vertex="1">
