          <mxGeometry x="1275" y="840" width="230" height="86" as="geometry" />
        </mxCell>
        <mxCell id="p2_08" value="accessCache loads getCollectionRights(user.roles)" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=14;align=center;verticalAlign=middle;fillColor=#f8cecc;strokeColor=#b85450;spacing=10;arcSize=8;" parent="1" vertex="1">
          <mxGeometry x="1875" y="960" width="230" height="88" as="geometry" />
        </mxCell>
        <mxCell id="p2_09" value="Build SQL with dynamic WHERE, joins, collectionAccessClause, and max 10000 limit" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=14;align=center;verticalAlign=middle;fillColor=#ffffff;strokeColor=#6c8ebf;spacing=10;arcSize=8;" parent="1" vertex="1">
          <mxGeometry x="1275" y="1085" width="230" height="102" as="geometry" />
        </mxCell>
        <mxCell id="p2_10" value="Execute candidate asset query" style="shape=cylinder3d;whiteSpace=wrap;boundedLbl=1;backgroundOutline=1;size=15;html=1;fontFamily=Helvetica;fontSize=14;align=center;verticalAlign=middle;fillColor=#f5f5f5;strokeColor=#666666;spacing=10;" parent="1" vertex="1">
          <mxGeometry x="1575" y="1225" width="230" height="76" as="geometry" />
        </mxCell>
        <mxCell id="p2_11" value="Filter full assets with checkRightsAsset(user, asset, false)" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=14;align=center;verticalAlign=middle;fillColor=#f8cecc;strokeColor=#b85450;spacing=10;arcSize=8;" parent="1" vertex="1">
