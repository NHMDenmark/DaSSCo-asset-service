        <mxCell id="p2_12" value="Load events and asset_specimens for readable GUIDs" style="shape=cylinder3d;whiteSpace=wrap;boundedLbl=1;backgroundOutline=1;size=15;html=1;fontFamily=Helvetica;fontSize=14;align=center;verticalAlign=middle;fillColor=#f5f5f5;strokeColor=#666666;spacing=10;" parent="1" vertex="1">
