          <mxGeometry x="375" y="345" width="230" height="86" as="geometry" />
        </mxCell>
        <mxCell id="p2_04" value="getAssetsFromQuery(queryResponses, limit)" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=14;align=center;verticalAlign=middle;fillColor=#ffffff;strokeColor=#6c8ebf;spacing=10;arcSize=8;" parent="1" vertex="1">
          <mxGeometry x="675" y="470" width="230" height="76" as="geometry" />
        </mxCell>
